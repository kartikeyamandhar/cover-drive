# Copy to .env and fill in. NEVER commit .env.
# Secrets are read only via pydantic-settings (configs/settings.py) and are never logged.
# No secret is required for Phase 0; these are consumed by later phases.

# Runtime knobs
APP_ENV=dev
LOG_JSON=false

# Hugging Face: base model download, dataset + adapter push, Mac<->RunPod transfer (Phase 4)
HF_TOKEN=

# Anthropic: teacher for distillation and the eval judge (Phase 2, Phase 5)
ANTHROPIC_API_KEY=

# Kaggle: style-seed and held-out eval reference corpus (Phase 2, Phase 3)
KAGGLE_USERNAME=
KAGGLE_KEY=

# RunPod: rented GPU for QLoRA training (Phase 4)
RUNPOD_API_KEY=

# Weights & Biases: optional training curves (Phase 4)
WANDB_API_KEY=
